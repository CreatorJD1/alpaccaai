# Runtime state -- her mood DB, memories, and telemetry. Telemetry can contain
# window titles (sensitive); none of this belongs in version control.
data/

# Extracted third-party handoff material (ComfyClaw / OpenClaw zips).
.handoff/

# Python
__pycache__/
*.pyc
# Dedicated Python 3.12 venv for talk mode (pyaudio has no 3.14 wheels).
.venv-talk/

# Local machine-specific Claude Code settings.
.claude/settings.local.json

# The Claude Code CLI binary, dropped in the repo root on this machine. It's a
# ~235 MB executable, well past GitHub's 100 MB limit -- never commit it.
claude.exe

# Vendored third-party engines (fish-speech TTS, Talking Head Anime 3). These are
# multi-GB checkouts -- model checkpoints, their own .venv/.git, weights well past
# GitHub's 100 MB file limit. They're fetched/set up locally, never committed.
vendor/
