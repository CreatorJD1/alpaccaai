# Inert defaults. A future provisioner may copy this to /etc/alpecca/runtime.env
# only after the Ubuntu fallback delivery gates pass.
ALPECCA_CLOUD_RUNTIME_ENABLED=0
ALPECCA_CLOUD_ROLE=standby
ALPECCA_CONVERSATIONAL_EGRESS_ENABLED=0
ALPECCA_SIDE_EFFECTS_REQUIRE_FENCE=1
ALPECCA_SUPERVISOR_MODE=dry-run
ALPECCA_APP_OPERATION_MODE=dry-run

# Linearizable authority placeholders. No URL, node identity, or credential is
# supplied by this repository.
ALPECCA_LEASE_AUTHORITY_URL=
ALPECCA_LEASE_NODE_ID=
ALPECCA_LEASE_RENEW_INTERVAL_SECONDS=10
ALPECCA_LEASE_DURATION_SECONDS=35
ALPECCA_PRIMARY_MISSED_GRACE_SECONDS=90
ALPECCA_LEASE_FENCING_EPOCH_REQUIRED=1

# The future supervisor must verify the newest encrypted snapshot before asking
# for leadership. Secrets come from the host secret store, never this file.
ALPECCA_MINDSCAPE_VAULT_URL=
ALPECCA_VAULT_VERIFICATION_REQUIRED=1
ALPECCA_RESTORE_BEFORE_LEADERSHIP=1

# No model or transport is started by this scaffold.
ALPECCA_MODEL=qwen3.5:9b
ALPECCA_DISCORD_ENABLED=0
ALPECCA_NOTIFICATIONS_ENABLED=0
ALPECCA_COMMITMENTS_ENABLED=0
