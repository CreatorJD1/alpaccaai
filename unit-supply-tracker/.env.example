# Copy this file to .env and fill in your Supabase project's values.
# Project Settings -> API in the Supabase dashboard.
#
# The anon key is safe to ship in a mobile build: it grants nothing on its own
# because every table is behind Row-Level Security (see supabase/migrations).
# NEVER put the service_role key in here or in the app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
